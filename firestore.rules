rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'harshyadav02201@gmail.com' &&
        request.auth.token.email_verified == true
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation Blueprints
    function isValidQuote(data) {
      return data.keys().hasAll(['name', 'email', 'phone', 'age', 'insuranceType', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.phone is string && data.phone.size() >= 10 && data.phone.size() <= 15 &&
             data.age is number && data.age >= 18 && data.age <= 100 &&
             data.insuranceType in ['term', 'endowment', 'ulip', 'retirement', 'child'] &&
             data.createdAt == request.time;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['name', 'email', 'content', 'createdAt']) &&
             data.keys().hasAny(['subject']) ? data.keys().size() <= 5 : data.keys().size() == 4 &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.email is string && data.email.size() <= 100 &&
             data.content is string && data.content.size() > 0 && data.content.size() <= 5000 &&
             data.createdAt == request.time;
    }

    function isValidBlogPost(data) {
      return data.keys().hasAll(['title', 'content', 'excerpt', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 200 &&
             data.content is string && data.content.size() > 0 &&
             data.createdAt == request.time;
    }

    // Collections
    match /quotes/{quoteId} {
      allow create: if isValidQuote(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /messages/{messageId} {
      allow create: if isValidMessage(incoming());
      allow read, update, delete: if isAdmin();
    }

    match /blogPosts/{postId} {
      allow read: if true;
      allow write: if isAdmin() && isValidBlogPost(incoming());
    }

    match /policies/{policyId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }

    match /claims/{claimId} {
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow write: if isAdmin();
    }
  }
}
